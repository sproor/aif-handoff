# ==========================================================
# AIF Handoff — Environment Configuration
# Copy this file to `.env` and adjust values as needed.
# Optional: create `.env.local` for machine-local overrides.
# ==========================================================

# ----------------------------------------------------------
# Ports
# ----------------------------------------------------------
PORT=3009
# WEB_PORT=5180
# WEB_HOST=localhost
DATABASE_URL=./data/aif.sqlite

# ----------------------------------------------------------
# Frontend Request Timeouts (compile-time constants)
# ----------------------------------------------------------
# These are NOT env vars — they are defined in packages/web/src/lib/api.ts.
# To change, edit the constants directly in the source file:
#   REQUEST_TIMEOUT_MS        = 15000    (CRUD requests)
#   PLAN_FAST_FIX_TIMEOUT_MS  = 200000   (AI plan fast fix)
#   CHAT_TIMEOUT_MS           = 300000   (chat with AI)
#   IMPORT_ROADMAP_TIMEOUT_MS = 300000   (roadmap import)

# ----------------------------------------------------------
# Docker
# ----------------------------------------------------------
# Host directory for project files (dev, bind mount)
# PROJECTS_DIR=./.projects
# Mount path for project files inside containers
# PROJECTS_MOUNT=/home/www

# Production: domain for SSL certificate (Let's Encrypt via ACME)
# DOMAIN=example.com

# Production: host ports for Angie
# HTTP_PORT=80
# HTTPS_PORT=443

# CORS origin restriction (`*` allows all origins)
# CORS_ORIGIN=http://localhost:5180

# ----------------------------------------------------------
# Agent Scheduler
# ----------------------------------------------------------
# How often coordinator polls for tasks (ms)
POLL_INTERVAL_MS=30000

# Per-stage hard timeout (planner/plan-checker/implementer/reviewer)
AGENT_STAGE_RUN_TIMEOUT_MS=3600000

# Stale task watchdog (ms + retries)
AGENT_STAGE_STALE_TIMEOUT_MS=5400000
AGENT_STAGE_STALE_MAX_RETRY=3

# Query startup guard:
# if no first stream message appears in timeout window,
# agent retries once after the delay below
AGENT_QUERY_START_TIMEOUT_MS=60000
AGENT_QUERY_START_RETRY_DELAY_MS=1000

# API one-shot runtime call timeouts (roadmap/fast-fix/commit generation)
API_RUNTIME_START_TIMEOUT_MS=60000
API_RUNTIME_RUN_TIMEOUT_MS=120000

# Max concurrent tasks per stage for parallel-enabled projects (default: 3)
# Non-parallel projects always process 1 task at a time regardless of this value
# COORDINATOR_MAX_CONCURRENT_TASKS=3

# ----------------------------------------------------------
# Agent Permissions
# ----------------------------------------------------------
# Bypass runtime permission checks for subagents (npm install, git, etc.)
# When false, configure allowed commands via .claude/settings.json (Claude adapter)
AGENT_BYPASS_PERMISSIONS=true

# Default for the per-task "Use subagents" setting (overridable in task Planner settings):
# true (default) — run via custom subagents (plan-coordinator/implement-coordinator/review-sidecar/security-sidecar)
# false — run via skills (aif-plan/aif-implement/aif-review/aif-security-checklist)
# AGENT_USE_SUBAGENTS=true

# Max turns (tool calls) for chat sessions before runtime terminates (default: 50):
# AGENT_CHAT_MAX_TURNS=50

# Max review→implement iterations in auto mode before moving task to Done (default: 3):
# AGENT_MAX_REVIEW_ITERATIONS=3

# ----------------------------------------------------------
# Runtime Provider Credentials
# ----------------------------------------------------------
# Claude adapter (SDK transport) — uses ~/.claude/ auth by default
# ANTHROPIC_API_KEY=sk-ant-xxxxx
# ANTHROPIC_AUTH_TOKEN=token-xxxxx        # alternative bearer-style credential for proxies
# ANTHROPIC_MODEL=claude-sonnet-4-5       # default model when profile.defaultModel is not set
# ANTHROPIC_BASE_URL=https://api.anthropic.com  # custom Anthropic-compatible endpoint

# Codex adapter (CLI/API transports)
# OPENAI_API_KEY=sk-openai-xxxxx
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-5.4

# Codex CLI transport — path to codex binary
# CODEX_CLI_PATH=/absolute/path/to/codex

# OpenRouter adapter (API transport) — unified API proxy for 200+ models
# OPENROUTER_API_KEY=sk-or-xxxxx
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=anthropic/claude-sonnet-4
# OPENROUTER_HTTP_REFERER=https://your-app.com
# OPENROUTER_APP_TITLE=AIF Handoff

# Default runtime/provider when no profile is configured (overrides built-in "claude"/"anthropic")
# AIF_DEFAULT_RUNTIME_ID=claude
# AIF_DEFAULT_PROVIDER_ID=anthropic

# Optional — comma-separated runtime module specifiers loaded at startup
# AIF_RUNTIME_MODULES=@org/runtime-module,file:///absolute/path/runtime-module.mjs

# API base URL used by agent for best-effort notifications
# API_BASE_URL=http://localhost:3009

# ----------------------------------------------------------
# MCP Server
# ----------------------------------------------------------
# Transport mode: "stdio" (default, for local Claude Code) or "http" (for Docker)
# MCP_TRANSPORT=stdio
# HTTP port when MCP_TRANSPORT=http (default: 3100)
# MCP_PORT=3100
# Rate limits
# MCP_RATE_LIMIT_READ_RPM=120
# MCP_RATE_LIMIT_WRITE_RPM=30

# ----------------------------------------------------------
# Observability
# ----------------------------------------------------------
AGENT_QUERY_AUDIT_ENABLED=false
LOG_LEVEL=debug

# Activity logging strategy: "sync" (per-event write) or "batch" (buffered flush)
# ACTIVITY_LOG_MODE=sync
# Max entries per flush (batch mode only)
# ACTIVITY_LOG_BATCH_SIZE=20
# Max age (ms) before auto-flush (batch mode only)
# ACTIVITY_LOG_BATCH_MAX_AGE_MS=5000
# Hard queue limit to prevent unbounded memory growth (batch mode only)
# ACTIVITY_LOG_QUEUE_LIMIT=500

# Enable event-driven wake channel (WebSocket subscription to API)
# Set to false to use polling-only mode
# AGENT_WAKE_ENABLED=true

# ----------------------------------------------------------
# Telegram Notifications (optional)
# ----------------------------------------------------------
# Best-effort messages on task status changes. If not set, disabled silently.
# TELEGRAM_BOT_API_URL=https://api.telegram.org
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_USER_ID=987654321
